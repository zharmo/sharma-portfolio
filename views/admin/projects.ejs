<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>
 <link rel="stylesheet" href="/css/projects.css">
<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title mb-0">Manage Projects</h1>
    <a href="/admin/dashboard" class="btn btn-secondary rounded-pill"><i class="fas fa-arrow-left me-2"></i>Back</a>
  </div>
  
  <!-- Add Project Form -->
  <div class="card shadow-sm mb-5 border-0 rounded-4">
    <div class="card-header bg-primary text-white rounded-top-4 py-3">
      <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Add New Project</h5>
    </div>
    <div class="card-body p-4">
      <form action="/admin/projects" method="POST" enctype="multipart/form-data">
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Title *</label>
            <input type="text" name="title" class="form-control" required>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-semibold">Technologies (comma separated)</label>
            <input type="text" name="technologies" class="form-control" placeholder="React, Node.js, MongoDB">
          </div>
          <div class="col-12 mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea name="description" rows="3" class="form-control"></textarea>
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">GitHub Link</label>
            <input type="url" name="github_link" class="form-control" placeholder="https://github.com/...">
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Live Demo Link</label>
            <input type="url" name="live_link" class="form-control" placeholder="https://...">
          </div>
          <div class="col-md-4 mb-3">
            <label class="form-label fw-semibold">Project Image</label>
            <input type="file" name="image" class="form-control" accept="image/*">
          </div>
          <div class="col-md-12 mb-3">
            <div class="form-check">
              <input type="checkbox" name="is_featured" class="form-check-input" id="featured">
              <label class="form-check-label" for="featured">Feature this project on homepage</label>
            </div>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="fas fa-save me-2"></i>Add Project</button>
          </div>
        </div>
      </form>
    </div>
  </div>
  
  <!-- Projects List -->
  <h3 class="mb-3">Existing Projects</h3>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Image</th><th>Title</th><th>Technologies</th><th>Featured</th><th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% projects.forEach(project => { %>
          <tr>
            <td><img src="<%= project.image_url || '/images/placeholder.png' %>" width="50" height="50" style="object-fit:cover; border-radius:8px;"></td>
            <td><strong><%= project.title %></strong></td>
            <td><%= project.technologies %></td>
            <td><% if (project.is_featured) { %><span class="badge bg-success">Featured</span><% } %></td>
            <td>
              <a href="/admin/projects/<%= project.id %>/delete" class="btn btn-sm btn-danger rounded-pill" onclick="return confirm('Delete this project?')"><i class="fas fa-trash"></i> Delete</a>
            </td>
          </tr>
        <% }) %>
        <% if (projects.length === 0) { %>
          <tr><td colspan="5" class="text-center text-muted">No projects yet. Add your first project above.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layouts/footer') %>