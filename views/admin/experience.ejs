<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title mb-0">Manage Work Experience</h1>
    <a href="/admin/dashboard" class="btn btn-secondary rounded-pill">Back</a>
  </div>
  
  <div class="card shadow-sm mb-5 border-0 rounded-4">
    <div class="card-header bg-primary text-white rounded-top-4 py-3">
      <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Add New Experience</h5>
    </div>
    <div class="card-body p-4">
      <form action="/admin/experience" method="POST">
        <div class="row g-3">
          <div class="col-md-6"><input type="text" name="title" class="form-control" placeholder="Job Title" required></div>
          <div class="col-md-6"><input type="text" name="company" class="form-control" placeholder="Company Name"></div>
          <div class="col-md-4"><input type="text" name="location" class="form-control" placeholder="Location"></div>
          <div class="col-md-3"><input type="text" name="start_date" class="form-control" placeholder="Start Date (e.g., 2022)"></div>
          <div class="col-md-3"><input type="text" name="end_date" class="form-control" placeholder="End Date (or Present)"></div>
          <div class="col-md-2">
            <select name="type" class="form-select">
              <option value="work">Work</option>
              <option value="education">Education</option>
              <option value="certification">Certification</option>
            </select>
          </div>
          <div class="col-12"><textarea name="description" rows="3" class="form-control" placeholder="Description"></textarea></div>
          <div class="col-12"><button type="submit" class="btn btn-primary rounded-pill px-4">Add Experience</button></div>
        </div>
      </form>
    </div>
  </div>
  
  <h3>Existing Experiences</h3>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead><tr><th>Title</th><th>Company</th><th>Period</th><th>Actions</th></tr></thead>
      <tbody>
        <% experiences.filter(e => e.type === 'work').forEach(exp => { %>
          <tr>
            <td><strong><%= exp.title %></strong></td>
            <td><%= exp.company %></td>
            <td><%= exp.start_date %> - <%= exp.end_date || 'Present' %></td>
            <td><a href="/admin/experience/<%= exp.id %>/delete" class="btn btn-sm btn-danger rounded-pill" onclick="return confirm('Delete?')">Delete</a></td>
          </tr>
        <% }) %>
        <% if (experiences.filter(e => e.type === 'work').length === 0) { %>
          <tr><td colspan="4" class="text-center text-muted">No work experience added.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../layouts/footer') %>