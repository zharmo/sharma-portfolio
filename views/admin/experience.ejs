<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title">Manage Work Experience</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addExpModal">+ Add Experience</button>
  </div>

  <div class="row">
    <% experiences.filter(e => e.type === 'work').forEach(exp => { %>
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h4><%= exp.title %></h4>
            <h6 class="text-muted"><%= exp.company %> | <%= exp.location %></h6>
            <p class="text-secondary"><%= exp.start_date %> - <%= exp.end_date || 'Present' %></p>
            <p><%= exp.description %></p>
            <a href="/admin/experience/<%= exp.id %>/delete" class="btn btn-sm btn-danger" onclick="return confirm('Delete this entry?')">Delete</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Add Experience Modal -->
<div class="modal fade" id="addExpModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">Add Work Experience</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/experience" method="POST">
        <div class="modal-body">
          <input type="hidden" name="type" value="work">
          <div class="mb-3">
            <label>Job Title</label>
            <input type="text" name="title" class="form-control" required>
          </div>
          <div class="mb-3">
            <label>Company</label>
            <input type="text" name="company" class="form-control" required>
          </div>
          <div class="mb-3">
            <label>Location</label>
            <input type="text" name="location" class="form-control">
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label>Start Date</label>
              <input type="text" name="start_date" class="form-control" placeholder="Jan 2023">
            </div>
            <div class="col-md-6 mb-3">
              <label>End Date</label>
              <input type="text" name="end_date" class="form-control" placeholder="Present or Dec 2024">
            </div>
          </div>
          <div class="mb-3">
            <label>Description</label>
            <textarea name="description" rows="4" class="form-control" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>