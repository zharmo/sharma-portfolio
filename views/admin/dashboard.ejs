<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title mb-0">Admin Dashboard</h1>
    <a href="/admin/logout" class="btn btn-outline-danger rounded-pill"><i class="fas fa-sign-out-alt me-2"></i>Logout</a>
  </div>
  <p class="text-muted">Welcome back, <strong><%= user.email %></strong></p>
  
  <div class="row g-4 mt-2">
    <div class="col-md-3">
      <div class="admin-card text-center p-4 bg-white rounded-4 shadow-sm">
        <i class="fas fa-project-diagram fa-3x text-primary mb-3"></i>
        <div class="number display-4 fw-bold text-primary"><%= projectCount %></div>
        <div class="text-muted mb-2">Projects</div>
        <a href="/admin/projects" class="btn btn-sm btn-outline-primary rounded-pill">Manage</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-card text-center p-4 bg-white rounded-4 shadow-sm">
        <i class="fas fa-envelope fa-3x text-primary mb-3"></i>
        <div class="number display-4 fw-bold text-primary"><%= messageCount %></div>
        <div class="text-muted mb-2">Messages</div>
        <a href="/admin/messages" class="btn btn-sm btn-outline-primary rounded-pill">View</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-card text-center p-4 bg-white rounded-4 shadow-sm">
        <i class="fas fa-code fa-3x text-primary mb-3"></i>
        <div class="number display-4 fw-bold text-primary"><%= skillCount %></div>
        <div class="text-muted mb-2">Skills</div>
        <a href="/admin/skills" class="btn btn-sm btn-outline-primary rounded-pill">Manage</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-card text-center p-4 bg-white rounded-4 shadow-sm">
        <i class="fas fa-briefcase fa-3x text-primary mb-3"></i>
        <div class="number display-4 fw-bold text-primary"><%= experienceCount %></div>
        <div class="text-muted mb-2">Experience</div>
        <a href="/admin/experience" class="btn btn-sm btn-outline-primary rounded-pill">Manage</a>
      </div>
    </div>
  </div>
  
  <div class="row g-4 mt-2">
    <div class="col-md-3">
      <a href="/admin/education" class="text-decoration-none">
        <div class="admin-card text-center p-4 bg-white rounded-4 shadow-sm">
          <i class="fas fa-graduation-cap fa-3x text-primary mb-3"></i>
          <div>Education</div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/admin/certificates" class="text-decoration-none">
        <div class="admin-card text-center p-4 bg-white rounded-4 shadow-sm">
          <i class="fas fa-certificate fa-3x text-primary mb-3"></i>
          <div>Certificates</div>
        </div>
      </a>
    </div>
    <div class="col-md-3">
      <a href="/admin/testimonials" class="text-decoration-none">
        <div class="admin-card text-center p-4 bg-white rounded-4 shadow-sm">
          <i class="fas fa-star fa-3x text-primary mb-3"></i>
          <div>Testimonials</div>
        </div>
      </a>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>