<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container my-5">
  <h1>Admin Dashboard</h1>
  <p>Welcome, <%= user.email %></p>
  <div class="row mt-4">
    <div class="col-md-3">
      <div class="admin-card">
        <div class="number"><%= projectCount %></div>
        <div>Projects</div>
        <a href="/admin/projects" class="btn btn-sm btn-outline-primary mt-2">Manage</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-card">
        <div class="number"><%= messageCount %></div>
        <div>Messages</div>
        <a href="/admin/messages" class="btn btn-sm btn-outline-primary mt-2">View</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-card">
        <div class="number"><%= skillCount %></div>
        <div>Skills</div>
        <a href="/admin/skills" class="btn btn-sm btn-outline-primary mt-2">Manage</a>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-card">
        <div class="number"><%= experienceCount %></div>
        <div>Experience</div>
        <a href="/admin/experience" class="btn btn-sm btn-outline-primary mt-2">Manage</a>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>