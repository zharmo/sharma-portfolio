<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title mb-0">Manage Testimonials</h1>
    <a href="/admin/dashboard" class="btn btn-secondary rounded-pill">Back to Dashboard</a>
  </div>

  <div class="card shadow-sm mb-5 border-0 rounded-4">
    <div class="card-header bg-primary text-white rounded-top-4 py-3">
      <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Add New Testimonial</h5>
    </div>
    <div class="card-body p-4">
      <form action="/admin/testimonials" method="POST" enctype="multipart/form-data">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Client Name *</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Position / Title</label>
            <input type="text" name="position" class="form-control">
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Review / Testimonial *</label>
            <textarea name="review" rows="4" class="form-control" required></textarea>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Client Image (optional)</label>
            <input type="file" name="image" class="form-control" accept="image/*">
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="fas fa-save me-2"></i>Add Testimonial</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <h3>Existing Testimonials</h3>
  <div class="row">
    <% testimonials.forEach(testimonial => { %>
      <div class="col-md-6 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <i class="fas fa-quote-left text-primary mb-2" style="font-size:1.5rem;"></i>
            <p class="card-text"><%= testimonial.review %></p>
            <div class="d-flex align-items-center mt-3">
              <img src="<%= testimonial.image_url || '/images/avatar-placeholder.png' %>" width="40" height="40" class="rounded-circle me-2">
              <div>
                <h6 class="mb-0"><%= testimonial.name %></h6>
                <small class="text-muted"><%= testimonial.position %></small>
              </div>
            </div>
            <a href="/admin/testimonials/<%= testimonial.id %>/delete" class="btn btn-sm btn-danger rounded-pill mt-3" onclick="return confirm('Delete this testimonial?')">Delete</a>
          </div>
        </div>
      </div>
    <% }) %>
    <% if (testimonials.length === 0) { %>
      <div class="col-12 text-center text-muted">No testimonials yet.</div>
    <% } %>
  </div>
</div>

<%- include('../layouts/footer') %>