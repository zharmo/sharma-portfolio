<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title">Manage Skills</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addSkillModal">+ Add New Skill</button>
  </div>

  <div class="row">
    <% 
      const grouped = {};
      skills.forEach(skill => {
        if (!grouped[skill.category]) grouped[skill.category] = [];
        grouped[skill.category].push(skill);
      });
    %>
    <% for (const [category, items] of Object.entries(grouped)) { %>
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><%= category %></h5>
          </div>
          <div class="card-body">
            <div class="row">
              <% items.forEach(skill => { %>
                <div class="col-12 mb-3">
                  <div class="d-flex justify-content-between align-items-center">
                    <span><strong><%= skill.name %></strong></span>
                    <span class="badge bg-primary"><%= skill.percentage || 'N/A' %>%</span>
                    <a href="/admin/skills/<%= skill.id %>/delete" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this skill?')">Delete</a>
                  </div>
                  <div class="progress mt-1" style="height: 8px;">
                   <div class="progress-bar" style="width: <%= skill.percentage || 0 %>%"></div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<!-- Add Skill Modal -->
<div class="modal fade" id="addSkillModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">Add New Skill</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/skills" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label>Category</label>
            <select name="category" class="form-select" required>
              <option value="Frontend">Frontend</option>
              <option value="Backend">Backend</option>
              <option value="Database">Database</option>
              <option value="Data Science">Data Science</option>
              <option value="Tools">Tools</option>
            </select>
          </div>
          <div class="mb-3">
            <label>Skill Name</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="mb-3">
            <label>Proficiency (%)</label>
            <input type="number" name="percentage" class="form-control" min="0" max="100" placeholder="e.g., 85">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Skill</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>