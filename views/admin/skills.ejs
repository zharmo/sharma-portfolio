<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

 <link rel="stylesheet" href="/css/skills.css">
<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title mb-0">Manage Skills</h1>
    <a href="/admin/dashboard" class="btn btn-secondary rounded-pill"><i class="fas fa-arrow-left me-2"></i>Back</a>
  </div>
  
  <!-- Add Skill Form -->
  <div class="card shadow-sm mb-5 border-0 rounded-4">
    <div class="card-header bg-primary text-white rounded-top-4 py-3">
      <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Add New Skill</h5>
    </div>
    <div class="card-body p-4">
      <form action="/admin/skills" method="POST">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label fw-semibold">Category</label>
            <select name="category" class="form-select" required>
              <option value="Frontend">Frontend</option>
              <option value="Backend">Backend</option>
              <option value="Database">Database</option>
              <option value="Data Science">Data Science</option>
              <option value="Tools">Tools</option>
            </select>
          </div>
          <div class="col-md-5">
            <label class="form-label fw-semibold">Skill Name</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="col-md-2">
            <label class="form-label fw-semibold">Percentage (0-100)</label>
            <input type="number" name="percentage" class="form-control" min="0" max="100">
          </div>
          <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary rounded-pill w-100"><i class="fas fa-save me-2"></i>Add</button>
          </div>
        </div>
      </form>
    </div>
  </div>
  
  <!-- Skills List Grouped -->
  <h3 class="mb-3">Your Skills</h3>
  <div class="row">
    <% 
      const grouped = {};
      skills.forEach(skill => {
        if (!grouped[skill.category]) grouped[skill.category] = [];
        grouped[skill.category].push(skill);
      });
      for (const [category, items] of Object.entries(grouped)) {
    %>
      <div class="col-md-6 mb-4">
        <div class="card h-100 border-0 shadow-sm rounded-4">
          <div class="card-header bg-white fw-bold py-3"><%= category %></div>
          <div class="card-body">
            <ul class="list-group list-group-flush">
              <% items.forEach(skill => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <%= skill.name %>
                  <% if (skill.percentage) { %><span class="badge bg-primary rounded-pill"><%= skill.percentage %>%</span><% } %>
                  <a href="/admin/skills/<%= skill.id %>/delete" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Delete <%= skill.name %>?')"><i class="fas fa-trash"></i></a>
                </li>
              <% }) %>
            </ul>
          </div>
        </div>
      </div>
    <% } %>
    <% if (skills.length === 0) { %>
      <div class="col-12 text-center text-muted">No skills added yet. Use the form above to add your first skill.</div>
    <% } %>
  </div>
</div>

<%- include('../layouts/footer') %>