<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<!-- Hero Section -->
<section class="hero">
  <div class="container text-center text-white position-relative" style="z-index: 2;">
    <img src="/images/profile/profile.jpg" class="rounded-circle mb-4" width="150" height="150" style="object-fit: cover; border: 4px solid white; box-shadow: var(--shadow-lg);" alt="Sharmarke Abdi Abdullahi">
    <h1 class="display-3 fw-bold">Sharmarke Abdi Abdullahi</h1>
    <p class="lead fs-4">Software Engineer | Full-Stack Developer | Data Science Enthusiast</p>
    <p class="mb-4">Building impactful tech solutions for Somalia, Africa, and beyond.</p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <a href="/resume" class="btn btn-light btn-lg rounded-pill px-4"><i class="fas fa-download me-2"></i>Download CV</a>
      <a href="/projects" class="btn btn-outline-light btn-lg rounded-pill px-4"><i class="fas fa-eye me-2"></i>View Projects</a>
      <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-4"><i class="fas fa-envelope me-2"></i>Contact Me</a>
    </div>
  </div>
</section>

<!-- Featured Projects -->
<section class="container my-5 py-4">
  <h2 class="section-title">Featured Projects</h2>
  <% if (typeof featuredProjects !== 'undefined' && featuredProjects && featuredProjects.length > 0) { %>
    <div class="row g-4">
      <% featuredProjects.forEach(function(project) { %>
        <div class="col-md-4">
          <div class="card h-100">
            <img src="<%= project.image_url || '/images/placeholder.png' %>" class="card-img-top" alt="<%= project.title %>">
            <div class="card-body">
              <h5 class="card-title fw-bold"><%= project.title %></h5>
              <p class="card-text text-muted"><%= project.description || '' %></p>
              <a href="/projects/<%= project.id %>" class="btn btn-sm btn-primary rounded-pill">Details</a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="alert alert-info">No featured projects yet. Check back soon!</div>
  <% } %>
</section>

<!-- Skills Preview -->
<section class="bg-light py-5">
  <div class="container">
    <h2 class="section-title">Core Skills</h2>
    <% if (typeof skills !== 'undefined' && skills && Object.keys(skills).length > 0) { %>
      <div class="row">
        <% 
          var skillEntries = Object.entries(skills);
          var firstTwo = skillEntries.slice(0, 2);
          for (var i = 0; i < firstTwo.length; i++) { 
            var category = firstTwo[i][0];
            var items = firstTwo[i][1];
            var skillArray = Array.isArray(items) ? items : [];
        %>
          <div class="col-md-6 mb-4">
            <h4 class="mb-3"><%= category %></h4>
            <% if (skillArray.length > 0) { %>
              <% for (var j = 0; j < Math.min(skillArray.length, 4); j++) { %>
                <div class="mb-2">
                  <span><%= skillArray[j].name %></span>
                  <div class="progress">
                   </div>
                  </div>
                </div>
              <% } %>
            <% } else { %>
              <p class="text-muted">No skills listed in this category.</p>
            <% } %>
          </div>
        <% } %>
      </div>
      <div class="text-center mt-4">
        <a href="/skills" class="btn btn-outline-primary rounded-pill">View All Skills <i class="fas fa-arrow-right ms-2"></i></a>
      </div>
    <% } else { %>
      <div class="alert alert-info">Skills data not available yet. Please add skills in the admin panel.</div>
    <% } %>
  </div>
</section>

<%- include('../layouts/footer') %>