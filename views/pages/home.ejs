<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<!-- Hero Section -->
<section class="hero">
  <div class="container text-center text-white position-relative" style="z-index: 2;">
    <img src="/images/profile/profile.jpg" class="rounded-circle mb-4" width="150" height="150" style="object-fit: cover; border: 4px solid white; box-shadow: var(--shadow-lg);" alt="Sharmarke Abdi Abdullahi">
    <h1 class="display-3 fw-bold"><%= __('hero_title') %></h1>
    <p class="lead fs-4"><%= __('hero_subtitle') %></p>
    <p class="mb-4"><%= __('hero_description') %></p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <a href="/resume" class="btn btn-light btn-lg rounded-pill px-4"><i class="fas fa-download me-2"></i><%= __('hero_btn_cv') %></a>
      <a href="/projects" class="btn btn-outline-light btn-lg rounded-pill px-4"><i class="fas fa-eye me-2"></i><%= __('hero_btn_projects') %></a>
      <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-4"><i class="fas fa-envelope me-2"></i><%= __('hero_btn_contact') %></a>
    </div>
  </div>
</section>

<!-- Featured Projects -->
<section class="container my-5 py-4">
  <h2 class="section-title"><%= __('featured_projects') %></h2>
  <% if (typeof featuredProjects !== 'undefined' && featuredProjects && featuredProjects.length > 0) { %>
    <div class="row g-4">
      <% featuredProjects.forEach(function(project) { %>
        <div class="col-md-4">
          <div class="card h-100">
            <img src="<%= project.image_url || '/images/placeholder.png' %>" class="card-img-top" alt="<%= project.title %>">
            <div class="card-body">
              <h5 class="card-title fw-bold"><%= project.title %></h5>
              <p class="card-text text-muted"><%= project.description || '' %></p>
              <a href="/projects/<%= project.id %>" class="btn btn-sm btn-primary rounded-pill"><%= __('details') %></a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="alert alert-info"><%= __('no_projects') %></div>
  <% } %>
</section>

<!-- Core Skills – ALL CATEGORIES -->
<section class="bg-light py-5">
  <div class="container">
    <h2 class="section-title"><%= __('core_skills') %></h2>
    <% if (typeof skills !== 'undefined' && skills && Object.keys(skills).length > 0) { %>
      <div class="row g-4">
        <% 
          var categoryEntries = Object.entries(skills);
          for (var i = 0; i < categoryEntries.length; i++) { 
            var category = categoryEntries[i][0];
            var items = categoryEntries[i][1];
            var skillArray = Array.isArray(items) ? items : [];
            // Map category key to translation key (lowercase, spaces -> underscore)
            var categoryKey = category.toLowerCase().replace(/ /g, '_');
        %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
              <div class="card-header bg-white fw-bold py-3 border-0" style="color: var(--primary); font-size: 1.2rem;">
                <i class="fas 
                  <% if(category === 'Frontend') { %>fa-code<% } 
                  else if(category === 'Backend') { %>fa-server<% }
                  else if(category === 'Database') { %>fa-database<% }
                  else if(category === 'Data Science') { %>fa-chart-line<% }
                  else { %>fa-tools<% } %> me-2"></i>
                <%= __(categoryKey) || category %>
              </div>
              <div class="card-body pt-0">
                <% if (skillArray.length > 0) { %>
                  <% for (var j = 0; j < skillArray.length; j++) { %>
                    <div class="mb-3">
                      <div class="d-flex justify-content-between mb-1">
                        <span class="skill-name"><%= skillArray[j].name %></span>
                        <span class="skill-percent"><%= skillArray[j].percentage || 80 %>%</span>
                      </div>
                  
                    </div>
                  <% } %>
                <% } else { %>
                  <p class="text-muted small"><%= __('no_skills') %></p>
                <% } %>
              </div>
            </div>
          </div>
        <% } %>
      </div>
      <div class="text-center mt-4">
        <a href="/skills" class="btn btn-outline-primary rounded-pill"><%= __('view_all_skills') %> <i class="fas fa-arrow-right ms-2"></i></a>
      </div>
    <% } else { %>
      <div class="alert alert-info"><%= __('no_skills_data') %></div>
    <% } %>
  </div>
</section>

<%- include('../layouts/footer') %>