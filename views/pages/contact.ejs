<%- include('../layouts/header') %>
<%- include('../layouts/navbar') %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h1 class="section-title">Contact Me</h1>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
        <div class="alert alert-danger">
          <% errors.forEach(err => { %><div><%= err.msg %></div><% }) %>
        </div>
      <% } %>
      <form action="/contact/send" method="POST" class="bg-white p-4 rounded-4 shadow-sm">
        <div class="mb-3">
          <label class="form-label fw-semibold">Your Name</label>
          <input type="text" name="name" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Email Address</label>
          <input type="email" name="email" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Message</label>
          <textarea name="message" rows="5" class="form-control" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary px-4">Send Message <i class="fas fa-paper-plane ms-2"></i></button>
      </form>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>